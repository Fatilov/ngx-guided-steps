{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/demo/browser",
  "installCommand": "npm install",
  "framework": null,
  "nodeVersion": "20.x",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
