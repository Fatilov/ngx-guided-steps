{
  "name": "ngx-guided-steps",
  "version": "1.0.0",
  "description": "Angular library for interactive guided tours, onboarding walkthroughs, and step-by-step tutorials with SVG overlays and WCAG accessibility.",
  "scripts": {
    "build": "ng build demo --configuration=production",
    "build:dev": "ng build demo --configuration=development",
    "serve": "ng serve demo",
    "build:lib": "ng build ngx-guided-steps --configuration=production",
    "lint": "tsc --noEmit --project demo/tsconfig.app.json",
    "test": "jest --config jest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fatilov/ngx-guided-steps"
  },
  "keywords": [
    "angular",
    "guided-tour",
    "onboarding",
    "walkthrough",
    "tutorial",
    "step-by-step",
    "ngx-guided-steps",
    "interactive-guide",
    "overlay"
  ],
  "engines": {
    "node": ">=20"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@angular/common": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "@angular/router": "^19.2.20",
    "rxjs": "^7.0.0",
    "zone.js": "~0.15.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.5",
    "tar": "^7.5.13"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.23",
    "@angular/cli": "^19.2.23",
    "@angular/compiler": "^19.2.20",
    "@angular/compiler-cli": "^19.2.20",
    "@playwright/test": "^1.58.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "^16.1.1",
    "ng-packagr": "^19.2.2",
    "playwright-core": "^1.52.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.6.0"
  }
}
